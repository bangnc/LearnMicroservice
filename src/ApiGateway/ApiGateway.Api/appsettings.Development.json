{
  "ReverseProxy": {

    "Routes": {
      "auth": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "users": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "files": {
        "ClusterId": "file-cluster",
        "Match": {
          "Path": "/api/files/{**catch-all}"
        }
      }
    },

    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": {
            "Address": "https://localhost:7092/"
          }
        }
      },

      "file-cluster": {
        "Destinations": {
          "file": {
            "Address": "https://localhost:7103/"
          }
        }
      }
    }
  },
  "Jwt": {
    "Key": "mF4v8X0y0qk3z0JqQk8cX9m2hYk3vQp1m5z8sQ==",
    "Issuer": "AuthService",
    "Audience": "ClientApp",
    "ExpireMinutes": 60
  }
}